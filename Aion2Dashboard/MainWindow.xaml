<Window x:Class="Aion2Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:Aion2Dashboard.Models"
        mc:Ignorable="d"
        Title="DPSVIEWER"
        Width="620"
        Height="500"
        MinWidth="430"
        MinHeight="300"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        Topmost="{Binding IsTopMost}"
        Opacity="{Binding WindowOpacityValue}">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#C5162130" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#4D6E97" />
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#28486D" />
        <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#6DA8E6" />
        <SolidColorBrush x:Key="SidebarButtonBrush" Color="#131F2E" />
        <SolidColorBrush x:Key="SidebarButtonBorderBrush" Color="#2E4C72" />

        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Foreground" Value="#EDF5FF" />
            <Setter Property="Background" Value="#1B2A3E" />
            <Setter Property="BorderBrush" Value="#4D739E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource WindowButton}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource SidebarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SidebarButtonBorderBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="InfoChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="0,0,6,4" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border Margin="10,10,28,28"
                Background="#A60E1723"
                BorderBrush="#8CCEF8FF"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="0,10,0,10"
                        Background="#73111A26"
                        BorderBrush="#355173"
                        BorderThickness="0,0,1,0"
                        CornerRadius="22,0,0,22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding RefreshServersCommand}"
                                    ToolTip="새로고침"
                                    Content="새" />
                            <Button Style="{StaticResource SidebarButton}"
                                    Click="OpenCombatRecords_Click"
                                    ToolTip="전투 기록"
                                    Content="기" />
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding CheckUpdateCommand}"
                                    ToolTip="{Binding UpdateButtonToolTip}">
                                <Grid Width="20" Height="20">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#EDF5FF"
                                               Text="업" />
                                    <Ellipse Width="8"
                                             Height="8"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Top"
                                             Margin="0,-1,-1,0"
                                             Fill="#FF5252"
                                             Stroke="#FFF5F5"
                                             StrokeThickness="1">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasUpdateNotification}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}"
                                    Click="OpenSettings_Click"
                                    ToolTip="설정"
                                    Content="설" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                            <Button Style="{StaticResource SidebarButton}"
                                    Click="ToggleCompact_Click"
                                    ToolTip="{Binding CompactButtonText}"
                                    Content="간" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#9F213557"
                            CornerRadius="0,22,0,0"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid Margin="12,8,12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#D7E8FF"
                                           Text="DPSVIEWER" />
                                <TextBlock Margin="7,3,0,0"
                                           Foreground="#AFC7E9"
                                           FontSize="10"
                                           Text="V4.0.16" />
                                <Border Margin="10,0,0,0"
                                        Padding="8,2"
                                        Background="#24152131"
                                        BorderBrush="#40658D"
                                        BorderThickness="1"
                                        CornerRadius="9">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding DetectionIndicatorBrush}" />
                                        <TextBlock Margin="6,0,0,0"
                                                   Foreground="#DCEBFF"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding DetectionStatus}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Margin="0,0,6,0"
                                           Foreground="#D2E0FA"
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           Text="투명도" />
                                <Slider Width="86"
                                        Minimum="0.55"
                                        Maximum="1.0"
                                        Value="{Binding WindowOpacityValue, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Style="{StaticResource WindowButton}"
                                        Margin="0,0,4,0"
                                        Click="Minimize_Click"
                                        Content="-" />
                                <Button Style="{StaticResource WindowButton}"
                                        Click="Close_Click"
                                        Content="X" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="10,10,10,0"
                            Padding="10,8"
                            Background="#A3162030"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompactMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <WrapPanel>
                            <Border Style="{StaticResource InfoChip}" Background="#354A67">
                                <TextBlock Foreground="#E0ECFF" FontSize="11" Text="{Binding MeterModeText}" />
                            </Border>
                            <Border Style="{StaticResource InfoChip}"
                                    Background="{Binding TargetBrush}"
                                    BorderBrush="{Binding TargetBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Foreground="#EFF6FF" FontSize="10" FontWeight="SemiBold" Text="{Binding TargetBadgeText}" />
                                    <TextBlock Margin="8,0,0,0" Foreground="White" FontSize="11" FontWeight="SemiBold" Text="{Binding CurrentTargetName}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InfoChip}" Background="#453654">
                                <TextBlock Foreground="#FFD96A" FontSize="11" FontWeight="SemiBold" Text="{Binding TotalPartyDps, StringFormat=PARTY DPS {0:N0}}" />
                            </Border>
                            <Border Style="{StaticResource InfoChip}" Background="#264B3B">
                                <TextBlock Foreground="#B9F4CE" FontSize="11" Text="{Binding CurrentTargetHealthText}" />
                            </Border>
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="10,10,10,8"
                            Padding="8"
                            Background="#9918212F"
                            BorderBrush="#4D719D"
                            BorderThickness="1"
                            CornerRadius="18">
                        <ListView x:Name="LivePlayersList"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ItemsSource="{Binding DisplayPlayers}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  MouseDoubleClick="LivePlayersList_MouseDoubleClick">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,6" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsCompactMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                            <Setter Property="Margin" Value="0,0,0,3" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DpsPlayerRow}">
                                    <Border Padding="8"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#CB2B3748" />
                                                <Setter Property="BorderBrush" Value="#5376A1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPartyCandidate}" Value="True">
                                                        <Setter Property="Background" Value="#CE32506C" />
                                                        <Setter Property="BorderBrush" Value="#79BBFF" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelf}" Value="True">
                                                        <Setter Property="Background" Value="#CC36586A" />
                                                        <Setter Property="BorderBrush" Value="#8AE1AF" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.IsCompactMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="Padding" Value="6" />
                                                        <Setter Property="CornerRadius" Value="10" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Width="34" Height="34" VerticalAlignment="Top">
                                                <Border Background="#213551"
                                                        CornerRadius="17"
                                                        BorderBrush="#79B6FF"
                                                        BorderThickness="1" />
                                                <Grid Margin="5">
                                                    <Image Source="{Binding JobImageUrl}" Stretch="Uniform">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasJobImage}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <Border Background="{Binding JobAccentBrush}"
                                                            BorderBrush="{Binding JobAccentBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="10">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasJobImage}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="White"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   Text="{Binding JobAccentText}" />
                                                    </Border>
                                                </Grid>
                                            </Grid>

                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <DockPanel LastChildFill="False">
                                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                        <TextBlock Foreground="White"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding DisplayName}" />
                                                        <TextBlock Margin="6,1,0,0"
                                                                   Foreground="#D7C9FF"
                                                                   FontSize="10"
                                                                   Text="{Binding CompactServerLabel}" />
                                                    </StackPanel>
                                                    <WrapPanel DockPanel.Dock="Right">
                                                        <Border Style="{StaticResource InfoChip}" Background="#37537F">
                                                            <TextBlock Foreground="#C6DAFF"
                                                                       FontSize="10"
                                                                       Text="{Binding CombatScore, StringFormat=아툴 {0:N0}}" />
                                                        </Border>
                                                    </WrapPanel>
                                                </DockPanel>

                                                <Grid Margin="0,5,0,0">
                                                    <WrapPanel VerticalAlignment="Center">
                                                        <WrapPanel.Style>
                                                            <Style TargetType="WrapPanel">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.IsCompactMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </WrapPanel.Style>
                                                        <Border Style="{StaticResource InfoChip}" Background="#274B72">
                                                            <TextBlock Foreground="#8ED6FF" FontSize="10" FontWeight="SemiBold" Text="{Binding Dps, StringFormat=DPS {0:N0}}" />
                                                        </Border>
                                                        <Border Style="{StaticResource InfoChip}" Background="#6A5821">
                                                            <TextBlock Foreground="#FFD96A" FontSize="10" FontWeight="SemiBold" Text="{Binding TotalDamage, StringFormat=누적 {0:N0}}" />
                                                        </Border>
                                                        <Border Style="{StaticResource InfoChip}" Background="#5A2F6D">
                                                            <TextBlock Foreground="#F2C2FF" FontSize="10" FontWeight="SemiBold" Text="{Binding PartyShareRatio, StringFormat=지분 {0:P0}}" />
                                                        </Border>
                                                        <Border Style="{StaticResource InfoChip}" Background="#275042">
                                                            <TextBlock Foreground="#A5F5CA" FontSize="10" FontWeight="SemiBold" Text="{Binding CritRate, StringFormat=치명 {0:P0}}" />
                                                        </Border>
                                                    </WrapPanel>

                                                    <Grid VerticalAlignment="Center">
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.IsCompactMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock DockPanel.Dock="Left" Foreground="#AFC7E9" FontSize="9" Text="DPS" />
                                                                <TextBlock DockPanel.Dock="Right" Foreground="#8ED6FF" FontSize="9" FontWeight="SemiBold" Text="{Binding Dps, StringFormat={}{0:N0}}" />
                                                            </DockPanel>
                                                            <ProgressBar Height="7" Margin="0,2,0,0" Maximum="1" Value="{Binding DpsRatio}" Foreground="#64BEFF" Background="#24344D" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock DockPanel.Dock="Left" Foreground="#AFC7E9" FontSize="9" Text="누적" />
                                                                <TextBlock DockPanel.Dock="Right" Foreground="#FFD96A" FontSize="9" FontWeight="SemiBold" Text="{Binding TotalDamage, StringFormat={}{0:N0}}" />
                                                            </DockPanel>
                                                            <ProgressBar Height="7" Margin="0,2,0,0" Maximum="1" Value="{Binding TotalDamageRatio}" Foreground="#F0C54C" Background="#3A321F" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock DockPanel.Dock="Left" Foreground="#AFC7E9" FontSize="9" Text="지분" />
                                                                <TextBlock DockPanel.Dock="Right" Foreground="#F2C2FF" FontSize="9" FontWeight="SemiBold" Text="{Binding PartyShareRatio, StringFormat={}{0:P0}}" />
                                                            </DockPanel>
                                                            <ProgressBar Height="7" Margin="0,2,0,0" Maximum="1" Value="{Binding PartyShareRatio}" Foreground="#B561E9" Background="#362444" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="3">
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock DockPanel.Dock="Left" Foreground="#AFC7E9" FontSize="9" Text="치명" />
                                                                <TextBlock DockPanel.Dock="Right" Foreground="#A5F5CA" FontSize="9" FontWeight="SemiBold" Text="{Binding CritRate, StringFormat={}{0:P0}}" />
                                                            </DockPanel>
                                                            <ProgressBar Height="7" Margin="0,2,0,0" Maximum="1" Value="{Binding CritRate}" Foreground="#75E7A2" Background="#1F3D30" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>

                    <Border Grid.Row="3"
                            Margin="10,0,10,10"
                            Padding="6,4"
                            Background="#64152030"
                            BorderBrush="#385170"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompactMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       Foreground="#D9E6FF"
                                       FontSize="10"
                                       Text="{Binding DetectionStatus}" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBlock Foreground="#A8BAD7"
                                           FontSize="10"
                                           Text="{Binding ResetHotkey, StringFormat={}{0} DPS 리셋}" />
                                <TextBlock Margin="10,0,0,0"
                                           Foreground="#A8BAD7"
                                           FontSize="10"
                                           Text="{Binding FullResetHotkey, StringFormat={}{0} 전체 리셋}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Thumb Width="74"
               Height="30"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,6,6"
               Background="Transparent"
               DragDelta="ResizeThumb_DragDelta">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="#355C8E"
                            BorderBrush="#8CC5FF"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid Margin="8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#EAF3FF"
                                       FontSize="10"
                                       Text="크기 조절" />
                            <Border Grid.Column="1"
                                    Width="16"
                                    Height="16"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="#EAF3FF"
                                    CornerRadius="3">
                                <Path Stroke="#4B74A4" StrokeThickness="1.2" Data="M3,13 L13,3 M7,13 L13,7 M10,13 L13,10" />
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</Window>

